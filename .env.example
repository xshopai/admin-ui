PORT=3001
REACT_APP_BFF_URL=http://localhost:8014

# Disable Fast Refresh to avoid CRA 5 ModuleScopePlugin blocking react-refresh's
# absolute-path runtime injection (known issue with react-scripts 5.0.1)
FAST_REFRESH=false

# Allow webpack-dev-server to accept requests from any hostname.
# Required in Codespaces (host is name-3001.app.github.dev, not localhost).
# Safe for local dev too.
DANGEROUSLY_DISABLE_HOST_CHECK=true

# Azure Application Insights (optional - for production telemetry)
# Telemetry is silently disabled if not configured
# REACT_APP_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx.applicationinsights.azure.com/
